---
import BaseLayout from '../components/layout/BaseLayout.astro';
import ConfirmDialog from '../components/ui/ConfirmDialog.astro';
import { getCollection } from 'astro:content';
import { buildNavTree } from '../lib/content';

const allEntries = await getCollection('chapters');
const navTree = await buildNavTree();

const entryMap = new Map(allEntries.map(e => [e.slug, e.data]));
const chapterData = navTree.map(chapter => ({ chapter }));

const difficultyLabel: Record<string, string> = {
  beginner: '入门',
  intermediate: '进阶',
  advanced: '高级',
};
const difficultyColor: Record<string, string> = {
  beginner: 'var(--color-success)',
  intermediate: 'var(--color-warning)',
  advanced: 'var(--color-error)',
};

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const firstChapterHref = navTree[0]?.href ?? `${base}/chapters`;
const totalArticles = navTree.reduce((sum, ch) => sum + 1 + ch.articles.length, 0);
const articleSlugs = navTree.flatMap(ch => [ch.indexSlug, ...ch.articles.map(a => a.slug)]);
---

<BaseLayout title="首页" description="HaloOS 系列讲解 — 整车操作系统架构与核心技术">
  <ConfirmDialog />
  <!-- Hero 区 -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <canvas id="matrix-canvas"></canvas>
    </div>
    <div class="hero-inner">
      <div class="hero-badge">VCOS · ADOS · VBS</div>
      <h1 class="hero-title">整车操作系统 <span class="accent">HaloOS</span> 系列讲解<br>(规划中)</h1>
      <p class="hero-subtitle">
        星环OS（HaloOS）是一款专为智能化与AI业务而生的整车操作系统，旨在为未来更前沿、更复杂的系统功能演进筑牢基石。
      </p>
      <div class="hero-actions">
        <a href={firstChapterHref} class="btn-primary" id="start-btn">开始学习 →</a>
      </div>
      <div class="hero-author">
        <img src={`${import.meta.env.BASE_URL.replace(/\/$/,'')}/images/logo.svg`} alt="雪云飞星" class="hero-avatar" width="18" height="18" loading="lazy" />
        <span>作者：雪云飞星（付皓文）</span>
        <span class="ai-badge">
          <svg width="10" height="10" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true"><path d="M6 0L7.2 4.8L12 6L7.2 7.2L6 12L4.8 7.2L0 6L4.8 4.8Z"/></svg>
          AI 协作
        </span>
      </div>
    </div>
  </section>

  <script define:vars={{ firstChapterHref, articleSlugs, base }} is:inline>
    // 矩阵雨：流式算法，彻底避免叠加
    (function () {
      const canvas = document.getElementById('matrix-canvas');
      if (!canvas || !(canvas instanceof HTMLCanvasElement)) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const FONT_SIZE  = 16;
      const COL_GAP    = 28;
      const TAIL_MIN   = 10;
      const TAIL_MAX   = 30;
      const SPEED_MIN  = 0.6;
      const SPEED_MAX  = 1.0;

      function makeStream(totalRows) {
        const tailLen = TAIL_MIN + Math.floor(Math.random() * (TAIL_MAX - TAIL_MIN));
        return {
          head:    -Math.floor(Math.random() * totalRows * 2),
          tailLen: tailLen,
          speed:   SPEED_MIN + Math.random() * (SPEED_MAX - SPEED_MIN),
          chars:   Array.from({ length: tailLen }, () => Math.random() < 0.5 ? '0' : '1'),
        };
      }

      let streams = [];
      let totalRows = 0;
      let totalCols = 0;
      ctx.font = `bold ${FONT_SIZE}px 'JetBrains Mono', monospace`;

      function init() {
        const parent = canvas.parentElement;
        if (!parent) return;
        canvas.width  = parent.offsetWidth;
        canvas.height = parent.offsetHeight;
        totalRows = Math.ceil(canvas.height / FONT_SIZE);
        totalCols = Math.ceil(canvas.width  / COL_GAP);
        streams = Array.from({ length: totalCols }, () => makeStream(totalRows));
      }

      init();
      window.addEventListener('resize', init);

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.font = `bold ${FONT_SIZE}px 'JetBrains Mono', monospace`;

        for (let col = 0; col < streams.length; col++) {
          const s = streams[col];
          const x = col * COL_GAP;

          for (let t = 0; t < s.tailLen; t++) {
            const row = Math.floor(s.head) - t;
            if (row < 0 || row >= totalRows) continue;

            const y = row * FONT_SIZE + FONT_SIZE;
            const tailAlpha = 1 - t / s.tailLen;
            const yAlpha = Math.max(0, 1 - y / canvas.height);
            const alpha = tailAlpha * yAlpha;

            if (t === 0) {
              ctx.fillStyle = `rgba(140, 220, 140, ${yAlpha})`;
            } else {
              ctx.fillStyle = `rgba(0, 114, 109, ${alpha * 0.9})`;
            }

            const char = (t === 0 && Math.random() < 0.15)
              ? (Math.random() < 0.5 ? '0' : '1')
              : s.chars[t % s.tailLen];

            ctx.fillText(char, x, y);
          }

          s.head += s.speed;

          if (Math.floor(s.head) > totalRows + s.tailLen + 2) {
            streams[col] = makeStream(totalRows);
          }
        }
      }

      setInterval(draw, 80);
    })();

    const STORAGE_KEY = 'rust-tutorial-last-visited:' + base;
    const last = localStorage.getItem(STORAGE_KEY);
    if (last) {
      if (articleSlugs.some(s => last === base + '/chapters/' + s)) {
        const btn = document.getElementById('start-btn');
        if (btn) btn.href = last;
      } else {
        localStorage.removeItem(STORAGE_KEY);
      }
    }
  </script>

  <!-- 课程大纲（完整目录） -->
  <section class="outline" id="outline">
    <div class="outline-inner">
      <div class="outline-header">
        <p class="section-label">课程目录</p>
        <div class="overall-progress" id="overall-progress" data-total={totalArticles} data-slugs={JSON.stringify(articleSlugs)}>
          <div class="overall-progress-track">
            <div class="overall-progress-fill" id="overall-progress-fill" style="width:0%"></div>
          </div>
          <div class="overall-progress-indicator" id="overall-progress-indicator">
            <span class="overall-progress-pct" id="overall-progress-pct">总进度 0%</span>
            <button type="button" id="outline-reset-all-btn" class="overall-reset-btn" aria-label="重置全部进度">↺ 重置全部进度</button>
          </div>
        </div>
      </div>
      {chapterData.map(({ chapter }) => {
        const indexData = entryMap.get(chapter.indexSlug);
        return (
          <div class="chapter-block" id={chapter.key}>

            <!-- 一级目录行 -->
            <div class="outline-item chapter-item">
              <a href={chapter.href} class="outline-link">
                <div class="item-main-row">
                  <span class="chapter-num-badge">{chapter.chapterNumber !== null ? String(chapter.chapterNumber).padStart(2, '0') : '序'}</span>
                  <span class="item-title">{chapter.title}</span>
                  {indexData && (
                    <span class="item-difficulty" style={`color: ${difficultyColor[indexData.difficulty]}`}>
                      {difficultyLabel[indexData.difficulty]}
                    </span>
                  )}
                  {indexData && <span class="item-time">⏱ {indexData.estimatedTime} 分钟</span>}
                </div>
                {indexData && (
                  <div class="item-sub-row">
                    <span class="item-desc">{indexData.description}</span>
                    {indexData.keywords.map(kw => <span class="item-kw">{kw}</span>)}
                  </div>
                )}
              </a>
              <div class="item-progress-area" data-slug={chapter.indexSlug}>
                <span class="progress-dot"></span>
                <button class="reset-btn" aria-label="重置该节进度">↺ 重置进度</button>
              </div>
            </div>

            <!-- 二级文章列表 -->
            {chapter.articles.length > 0 && (
              <ul class="article-list">
                {chapter.articles.map((article, articleIdx) => {
                  const data = entryMap.get(article.slug);
                  return (
                    <li class="outline-item article-item">
                      <a href={article.href} class="outline-link">
                        <div class="item-main-row">
                          <span class="article-num">{chapter.chapterNumber !== null ? `${chapter.chapterNumber}.${articleIdx + 1}` : `序.${articleIdx + 1}`}</span>
                          <span class="item-title">{article.title}</span>
                          {data && (
                            <span class="item-difficulty" style={`color: ${difficultyColor[data.difficulty]}`}>
                              {difficultyLabel[data.difficulty]}
                            </span>
                          )}
                          {data && <span class="item-time">⏱ {data.estimatedTime} 分钟</span>}
                        </div>
                        {data && (
                          <div class="item-sub-row">
                            <span class="item-desc">{data.description}</span>
                            {data.keywords.map(kw => <span class="item-kw">{kw}</span>)}
                          </div>
                        )}
                      </a>
                      <div class="item-progress-area" data-slug={article.slug}>
                        <span class="progress-dot"></span>
                        <button class="reset-btn" aria-label="重置该节进度">↺ 重置进度</button>
                      </div>
                    </li>
                  );
                })}
              </ul>
            )}

          </div>
        );
      })}
    </div>
  </section>

  <div class="site-pv" id="busuanzi_container_site_pv" style="display:none">
    <span class="site-pv-rule"></span>
    <span class="site-pv-text">本站累计访问 <span id="busuanzi_value_site_pv"></span> 次</span>
    <span class="site-pv-rule"></span>
  </div>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 1.5rem;
    text-align: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  #matrix-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 999px;
    padding: 0.25rem 0.875rem;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .accent {
    color: var(--color-accent);
  }

  .hero-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-author {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 1.25rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    opacity: 0.65;
  }

  .hero-avatar {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid rgba(206, 164, 114, 0.6);
    border-radius: 999px;
    color: var(--color-accent);
    opacity: 0.8;
  }

  .site-pv {
    display: flex !important;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 8rem 1.5rem 2rem;
    margin: 0;
  }

  .site-pv-rule {
    display: block;
    flex-shrink: 0;
    width: 2.5rem;
    height: 1px;
    background: var(--color-border);
    opacity: 0.5;
  }

  .site-pv-text {
    font-size: 0.68rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    opacity: 0.4;
    white-space: nowrap;
  }

  /* 课程大纲 */
  .outline {
    padding: 3rem 1.5rem 2rem;
    scroll-margin-top: var(--navbar-height);
  }

  .outline-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .outline-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .overall-progress {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex: 1;
    min-width: 0;
  }

  .overall-progress-track {
    flex: 1;
    height: 3px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .overall-progress-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  /* 指示器：百分比与重置按钮 grid 叠放 */
  .overall-progress-indicator {
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  .overall-progress-pct {
    grid-area: 1 / 1;
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    min-width: 4.5rem;
    text-align: center;
    pointer-events: none;
    transition: opacity 0.15s;
  }

  .overall-reset-btn {
    grid-area: 1 / 1;
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.1rem 0.5rem;
    height: 22px;
    border-radius: 4px;
    border: 1px solid rgba(206, 65, 43, 0.5);
    background: transparent;
    cursor: pointer;
    color: var(--color-error);
    font-size: 0.75rem;
    font-family: var(--font-sans);
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s, visibility 0.15s, border-color 0.15s, background 0.15s;
  }

  .overall-progress-indicator[data-has-progress="true"]:hover .overall-progress-pct {
    opacity: 0;
  }

  .overall-progress-indicator[data-has-progress="true"]:hover .overall-reset-btn {
    opacity: 1;
    visibility: visible;
  }

  .overall-reset-btn:hover {
    border-color: var(--color-error);
    background: rgba(206, 65, 43, 0.12);
  }
</style>

<style is:global>
  /* 课程大纲 */
  #outline .chapter-block {
    border-top: 1px solid var(--color-border);
    scroll-margin-top: calc(var(--navbar-height) + 1rem);
  }

  #outline .chapter-block:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  /* 每一行（章节或文章）的外层容器 */
  #outline .outline-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  #outline .chapter-item {
    padding: 1rem 0.5rem 0.875rem;
  }

  #outline .article-list {
    list-style: none;
    padding: 0 0 0.75rem 2.5rem;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  #outline .article-item {
    padding: 0.5rem 0.5rem;
    border-radius: 6px;
    transition: background 0.15s;
  }

  #outline .article-item:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  /* 链接区域（flex 列：主行 + 副行） */
  #outline .outline-link {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    text-decoration: none;
  }

  /* 主行：编号 + 标题 + 难度 + 时间（同一行紧挨着） */
  #outline .item-main-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: nowrap;
    min-width: 0;
  }

  #outline .chapter-num-badge {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-border);
    font-family: var(--font-mono);
    flex-shrink: 0;
  }

  #outline .article-num {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    opacity: 0.55;
    flex-shrink: 0;
  }

  #outline .chapter-item .item-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s;
  }

  #outline .article-item .item-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(232, 232, 232, 0.78);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s;
  }

  #outline .outline-link:hover .item-title {
    color: var(--color-accent);
  }

  #outline .item-difficulty {
    font-size: 0.75rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  #outline .item-time {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  #outline .chapter-item .item-sub-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding-left: 2.25rem;
  }

  #outline .article-item .item-sub-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding-left: 1.875rem;
  }

  #outline .chapter-item .item-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-right: 0.25rem;
  }

  #outline .article-item .item-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.65;
    margin-right: 0.25rem;
  }

  #outline .item-kw {
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    padding: 0.1rem 0.45rem;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  /* 右侧进度区域：grid 叠放，进度灯与重置按钮互换 */
  #outline .item-progress-area {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    padding-top: 0.15rem;
  }

  #outline .progress-dot {
    grid-area: 1 / 1;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    pointer-events: none;
    transition: opacity 0.15s, border-color 0.15s, background 0.15s;
  }

  #outline .item-progress-area[data-has-progress="true"]:hover .progress-dot {
    opacity: 0;
  }

  #outline .reset-btn {
    grid-area: 1 / 1;
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.1rem 0.5rem;
    height: 22px;
    border-radius: 4px;
    border: 1px solid rgba(206, 65, 43, 0.5);
    background: transparent;
    cursor: pointer;
    color: var(--color-error);
    font-size: 0.75rem;
    font-family: var(--font-sans);
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s, visibility 0.15s, border-color 0.15s, background 0.15s;
  }

  #outline .item-progress-area[data-has-progress="true"]:hover .reset-btn {
    opacity: 1;
    visibility: visible;
  }

  #outline .reset-btn:hover {
    border-color: var(--color-error);
    background: rgba(206, 65, 43, 0.12);
  }
</style>

<script>
  import { resetArticle, resetAll, getOverallProgress } from '../lib/progress';

  function syncProgressDots(): void {
    let store: { articles?: Record<string, { status: string }> } = {};
    try {
      const raw = localStorage.getItem('rust-tutorial-progress');
      if (raw) store = JSON.parse(raw) as typeof store;
    } catch {
      // ignore
    }

    document
      .querySelectorAll<HTMLElement>('.item-progress-area[data-slug]')
      .forEach((area) => {
        const slug = area.dataset.slug ?? '';
        const status = store.articles?.[slug]?.status ?? 'not-started';
        const dot = area.querySelector<HTMLElement>('.progress-dot');
        if (!dot) return;

        if (status === 'completed') {
          dot.style.background = 'var(--color-success)';
          dot.style.borderColor = 'var(--color-success)';
        } else if (status === 'in-progress') {
          dot.style.background = 'rgba(245, 158, 11, 0.2)';
          dot.style.borderColor = 'var(--color-warning)';
        } else {
          dot.style.background = '';
          dot.style.borderColor = '';
        }
        area.dataset.hasProgress = String(status !== 'not-started');
      });

    const hasAnyProgress = Object.values(store.articles ?? {}).some(
      (a) => a.status !== 'not-started'
    );
    const indicatorEl = document.getElementById('overall-progress-indicator');
    if (indicatorEl) {
      indicatorEl.dataset.hasProgress = String(hasAnyProgress);
    }

    const progressEl = document.getElementById('overall-progress');
    const total = Number(progressEl?.dataset.total ?? 0);
    const validSlugs = new Set<string>(JSON.parse(progressEl?.dataset.slugs ?? '[]'));
    const pct = getOverallProgress(total, validSlugs);
    const fill = document.getElementById('overall-progress-fill');
    const pctEl = document.getElementById('overall-progress-pct');
    if (fill) fill.style.width = `${pct}%`;
    if (pctEl) pctEl.textContent = `总进度 ${pct}%`;
  }

  syncProgressDots();
  window.addEventListener('progress-updated', syncProgressDots);

  // ↺ 悬停按钮：重置单篇文章
  document.querySelectorAll<HTMLElement>('.item-progress-area[data-slug]').forEach((area) => {
    const resetBtn = area.querySelector<HTMLButtonElement>('.reset-btn');
    if (!resetBtn) return;
    const slug = area.dataset.slug ?? '';
    if (!slug) return;
    resetBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      resetArticle(slug);
    });
  });

  // 全部重置（需输入确认文字）
  document.getElementById('outline-reset-all-btn')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('confirm-dialog:open', {
      detail: {
        message: '此操作将清除全部学习进度，无法撤销。',
        confirmText: '重置全部进度',
        onConfirm: resetAll,
      },
    }));
  });
