---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { buildNavTree } from '../lib/content';

const allEntries = await getCollection('chapters');
const navTree = await buildNavTree();

const entryMap = new Map(allEntries.map(e => [e.slug, e.data]));
const chapterData = navTree.map(chapter => ({ chapter }));

const difficultyLabel: Record<string, string> = {
  beginner: '入门',
  intermediate: '进阶',
  advanced: '高级',
};
const difficultyColor: Record<string, string> = {
  beginner: 'var(--color-success)',
  intermediate: 'var(--color-warning)',
  advanced: 'var(--color-error)',
};

const firstChapterHref = navTree[0]?.href ?? '/chapters';
---

<BaseLayout title="首页" description="RUST 互动教程 — 零基础系统学习 Rust 语言">
  <!-- Hero 区 -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>
    <div class="hero-inner">
      <div class="hero-badge">系统 · 互动 · 零基础</div>
      <h1 class="hero-title">
        <span class="accent">RUST</span> 互动教程<span class="wip">（搭建中）</span>
      </h1>
      <p class="hero-subtitle">
        像官方 Rust Book 一样系统讲解，加入在线代码执行、可编辑练习、章节测验等互动功能。从第一行代码开始，逐步掌握 Rust 语言。
      </p>
      <div class="hero-actions">
        <a href={firstChapterHref} class="btn-primary" id="start-btn">开始学习 →</a>
      </div>
    </div>
  </section>

  <script define:vars={{ firstChapterHref }} is:inline>
    const last = localStorage.getItem('rust-tutorial-last-visited');
    if (last) {
      const btn = document.getElementById('start-btn');
      if (btn) btn.href = last;
    }
  </script>

  <!-- 课程大纲（完整目录） -->
  <section class="outline" id="outline">
    <div class="outline-inner">
      <p class="section-label">课程目录</p>
      {chapterData.map(({ chapter }) => {
        const indexData = entryMap.get(chapter.indexSlug);
        return (
          <div class="chapter-block" id={chapter.key}>

            <!-- 一级目录行 -->
            <div class="outline-item chapter-item">
              <a href={chapter.href} class="outline-link">
                <div class="item-main-row">
                  <span class="chapter-num-badge">{chapter.chapterNumber !== null ? String(chapter.chapterNumber).padStart(2, '0') : '序'}</span>
                  <span class="item-title">{chapter.title}</span>
                  {indexData && (
                    <span class="item-difficulty" style={`color: ${difficultyColor[indexData.difficulty]}`}>
                      {difficultyLabel[indexData.difficulty]}
                    </span>
                  )}
                  {indexData && <span class="item-time">⏱ {indexData.estimatedTime} 分钟</span>}
                </div>
                {indexData && (
                  <div class="item-sub-row">
                    <span class="item-desc">{indexData.description}</span>
                    {indexData.keywords.map(kw => <span class="item-kw">{kw}</span>)}
                  </div>
                )}
              </a>
              <div class="item-progress-area" data-slug={chapter.indexSlug}>
                <span class="progress-dot"></span>
                <button class="reset-btn" aria-label="重置进度" title="重置进度">↺</button>
              </div>
            </div>

            <!-- 二级文章列表 -->
            {chapter.articles.length > 0 && (
              <ul class="article-list">
                {chapter.articles.map((article, articleIdx) => {
                  const data = entryMap.get(article.slug);
                  return (
                    <li class="outline-item article-item">
                      <a href={article.href} class="outline-link">
                        <div class="item-main-row">
                          <span class="article-num">{chapter.chapterNumber !== null ? `${chapter.chapterNumber}.${articleIdx + 1}` : `序.${articleIdx + 1}`}</span>
                          <span class="item-title">{article.title}</span>
                          {data && (
                            <span class="item-difficulty" style={`color: ${difficultyColor[data.difficulty]}`}>
                              {difficultyLabel[data.difficulty]}
                            </span>
                          )}
                          {data && <span class="item-time">⏱ {data.estimatedTime} 分钟</span>}
                        </div>
                        {data && (
                          <div class="item-sub-row">
                            <span class="item-desc">{data.description}</span>
                            {data.keywords.map(kw => <span class="item-kw">{kw}</span>)}
                          </div>
                        )}
                      </a>
                      <div class="item-progress-area" data-slug={article.slug}>
                        <span class="progress-dot"></span>
                        <button class="reset-btn" aria-label="重置进度" title="重置进度">↺</button>
                      </div>
                    </li>
                  );
                })}
              </ul>
            )}

          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 1.5rem;
    text-align: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .orb-1 {
    width: 560px;
    height: 380px;
    background: radial-gradient(circle at 40% 40%, rgba(206, 65, 43, 0.22), transparent 70%);
    top: -120px;
    left: 50%;
    animation: orb-drift-1 18s ease-in-out infinite;
  }

  .orb-2 {
    width: 400px;
    height: 300px;
    background: radial-gradient(circle at 50% 50%, rgba(217, 119, 6, 0.15), transparent 70%);
    top: -80px;
    left: -80px;
    animation: orb-drift-2 22s ease-in-out infinite;
  }

  .orb-3 {
    width: 300px;
    height: 240px;
    background: radial-gradient(circle at 50% 50%, rgba(99, 55, 180, 0.12), transparent 70%);
    bottom: 0;
    right: 5%;
    animation: orb-drift-3 15s ease-in-out infinite;
  }

  @keyframes orb-drift-1 {
    0%, 100% { transform: translateX(-30%) translateY(0) scale(1); }
    35%       { transform: translateX(-20%) translateY(-30px) scale(1.06); }
    70%       { transform: translateX(-40%) translateY(20px) scale(0.96); }
  }

  @keyframes orb-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    40%       { transform: translate(30px, -25px) scale(1.08); }
    75%       { transform: translate(-20px, 15px) scale(0.94); }
  }

  @keyframes orb-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%       { transform: translate(-25px, -20px) scale(1.1); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 640px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 999px;
    padding: 0.25rem 0.875rem;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .accent {
    color: var(--color-accent);
  }

  .hero-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* 课程大纲 */
  .outline {
    padding: 3rem 1.5rem 5rem;
    scroll-margin-top: var(--navbar-height);
  }

  .outline-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
</style>

<style is:global>
  /* 课程大纲 */
  #outline .chapter-block {
    border-top: 1px solid var(--color-border);
    scroll-margin-top: calc(var(--navbar-height) + 1rem);
  }

  #outline .chapter-block:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  /* 每一行（章节或文章）的外层容器 */
  #outline .outline-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  #outline .chapter-item {
    padding: 1rem 0.5rem 0.875rem;
  }

  #outline .article-list {
    list-style: none;
    padding: 0 0 0.75rem 2.5rem;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  #outline .article-item {
    padding: 0.5rem 0.5rem;
    border-radius: 6px;
    transition: background 0.15s;
  }

  #outline .article-item:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  /* 链接区域（flex 列：主行 + 副行） */
  #outline .outline-link {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    text-decoration: none;
  }

  /* 主行：编号 + 标题 + 难度 + 时间（同一行紧挨着） */
  #outline .item-main-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: nowrap;
    min-width: 0;
  }

  #outline .chapter-num-badge {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-border);
    font-family: var(--font-mono);
    flex-shrink: 0;
  }

  #outline .article-num {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    opacity: 0.55;
    flex-shrink: 0;
  }

  #outline .chapter-item .item-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s;
  }

  #outline .article-item .item-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(232, 232, 232, 0.78);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s;
  }

  #outline .outline-link:hover .item-title {
    color: var(--color-accent);
  }

  #outline .item-difficulty {
    font-size: 0.75rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  #outline .item-time {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  #outline .chapter-item .item-sub-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding-left: 2.25rem;
  }

  #outline .article-item .item-sub-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding-left: 1.875rem;
  }

  #outline .chapter-item .item-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-right: 0.25rem;
  }

  #outline .article-item .item-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.65;
    margin-right: 0.25rem;
  }

  #outline .item-kw {
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    padding: 0.1rem 0.45rem;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  /* 右侧进度区域 */
  #outline .item-progress-area {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
    padding-top: 0.15rem;
  }

  #outline .progress-dot {
    display: inline-flex;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    flex-shrink: 0;
    transition: border-color 0.15s, background 0.15s;
  }

  #outline .reset-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 4px;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s, visibility 0.15s, background 0.15s, color 0.15s;
  }

  #outline .item-progress-area:hover .reset-btn {
    opacity: 1;
    visibility: visible;
  }

  #outline .reset-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text);
  }
</style>

<script>
  function syncProgressDots(): void {
    let store: { articles?: Record<string, { status: string }> } = {};
    try {
      const raw = localStorage.getItem('rust-tutorial-progress');
      if (raw) store = JSON.parse(raw) as typeof store;
    } catch {
      // ignore
    }

    document
      .querySelectorAll<HTMLElement>('.item-progress-area[data-slug]')
      .forEach((area) => {
        const slug = area.dataset.slug ?? '';
        const status = store.articles?.[slug]?.status ?? 'not-started';
        const dot = area.querySelector<HTMLElement>('.progress-dot');
        if (!dot) return;

        if (status === 'completed') {
          dot.style.background = 'var(--color-success)';
          dot.style.borderColor = 'var(--color-success)';
        } else if (status === 'in-progress') {
          dot.style.background = 'rgba(245, 158, 11, 0.2)';
          dot.style.borderColor = 'var(--color-warning)';
        } else {
          dot.style.background = '';
          dot.style.borderColor = '';
        }
      });
  }

  syncProgressDots();
  window.addEventListener('progress-updated', syncProgressDots);
</script>
