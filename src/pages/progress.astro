---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout title="学习进度">
  <div class="placeholder-page">
    <h1>学习进度</h1>
    <p>此功能将在子计划 4（进度系统）中实现。</p>
    <a href="/" class="btn-secondary">← 返回首页</a>
  </div>
</BaseLayout>

<style>
  .placeholder-page {
    max-width: var(--content-max-width);
    margin: 5rem auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .placeholder-page h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .placeholder-page p {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
</style>
