---
import { getCollection } from 'astro:content';
import ChapterLayout from '../../components/layout/ChapterLayout.astro';
import SectionProgress from '../../components/ui/SectionProgress.astro';
import { buildNavTree, getFlatArticleList, type BreadcrumbItem } from '../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('chapters');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const navTree = await buildNavTree();
const flatList = await getFlatArticleList(navTree);

const currentIdx = flatList.findIndex(a => a.slug === entry.slug);
const prevArticle = currentIdx > 0 ? flatList[currentIdx - 1] : undefined;
const nextArticle = currentIdx < flatList.length - 1 ? flatList[currentIdx + 1] : undefined;

const currentChapter = navTree.find(
  ch => ch.indexSlug === entry.slug || ch.articles.some(a => a.slug === entry.slug)
);

const isChapterIndex = currentChapter?.indexSlug === entry.slug;
const breadcrumb: BreadcrumbItem[] = [
  { label: '课程', href: '/' },
  ...(currentChapter && !isChapterIndex
    ? [{ label: currentChapter.title, href: currentChapter.href }]
    : []),
  { label: entry.data.title },
];
---

<ChapterLayout
  title={entry.data.title}
  description={entry.data.description}
  navTree={navTree}
  currentSlug={entry.slug}
  headings={headings}
  breadcrumb={breadcrumb}
  prevArticle={prevArticle}
  nextArticle={nextArticle}
>
  <script>
    localStorage.setItem('rust-tutorial-last-visited', window.location.pathname);
  </script>
  <article class="prose">
    <h1>{entry.data.title}</h1>
    <div class="article-meta">
      <span class:list={['meta-difficulty', `difficulty-${entry.data.difficulty}`]}>
        {entry.data.difficulty === 'beginner' ? '入门' : entry.data.difficulty === 'intermediate' ? '进阶' : '高级'}
      </span>
      <span class="meta-time">⏱ {entry.data.estimatedTime} 分钟</span>
      {entry.data.keywords.map(kw => (
        <span class="meta-keyword">{kw}</span>
      ))}
    </div>
    <SectionProgress headings={headings} articleSlug={entry.slug}>
      <div id="article-content">
        <Content />
      </div>
    </SectionProgress>
  </article>
</ChapterLayout>

<style>
  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
  }

  .meta-difficulty {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .difficulty-beginner {
    background: rgba(34, 197, 94, 0.12);
    color: var(--color-success);
  }

  .difficulty-intermediate {
    background: rgba(245, 158, 11, 0.12);
    color: var(--color-warning);
  }

  .difficulty-advanced {
    background: rgba(239, 68, 68, 0.12);
    color: var(--color-error);
  }

  .meta-time {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .meta-keyword {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }
</style>
