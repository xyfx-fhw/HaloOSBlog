---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { buildNavTree, getFlatArticleList } from '../lib/content';

// 开关：true = 正常开放证书；false = 课程更新中，暂不开放
const CERTIFICATE_ENABLED = true;

const navTree = await buildNavTree();
const flatList = await getFlatArticleList(navTree);
const totalArticles = flatList.length;
---

<BaseLayout title="学习证书">
  <div class="cert-page">

    {CERTIFICATE_ENABLED ? (
      <Fragment>
        <!-- 状态一：进度不足 -->
        <div class="state state-locked" style="display:none">
          <div class="lock-icon">🔒</div>
      <h1>证书尚未解锁</h1>
      <p class="desc">
        你当前完成了 <strong class="pct-text">0%</strong>，完成 <strong>100%</strong> 的课程内容后可领取证书。
      </p>
      <div class="progress-wrap">
        <div class="progress-track">
          <div class="progress-fill" style="width:0%"></div>
        </div>
        <span class="progress-label pct-text">0%</span>
      </div>
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/chapters`} class="btn-secondary">← 继续学习</a>
    </div>

    <!-- 状态二：填写姓名 -->
    <div class="state state-name-form" style="display:none">
      <div class="congrats-icon">🎉</div>
      <h1>恭喜完成学习！</h1>
      <p class="desc">请输入你的姓名，将显示在证书上：</p>
      <form class="name-form" id="nameForm">
        <input
          type="text"
          id="nameInput"
          class="name-input"
          placeholder="你的姓名"
          maxlength="40"
          autocomplete="name"
        />
        <button type="submit" class="btn-primary">领取证书</button>
      </form>
      <p class="form-error" id="formError" style="display:none">请输入有效的姓名。</p>
    </div>

    <!-- 状态三：展示证书 -->
    <div class="state state-certificate" style="display:none">
      <div class="cert-card" id="certCard">
        <div class="cert-top-bar"></div>
        <div class="cert-inner">
          <div class="cert-header">
            <div class="cert-title">RUST 互动教程</div>
            <div class="cert-subtitle">学 习 证 书</div>
          </div>

          <div class="cert-divider-wrap">
            <span class="cert-divider-line"></span>
            <span class="cert-divider-diamond">◆</span>
            <span class="cert-divider-line"></span>
          </div>

          <div class="cert-body">
            <p class="cert-label">兹 证 明</p>
            <p class="cert-name" id="certName">——</p>
            <p class="cert-completion">
              已完成《RUST互动教程》（本课程）<span class="cert-pct" id="certPct">0%</span> 的学习内容，<br>并通过了所有的测验
            </p>
            <p class="cert-date" id="certDate">——</p>
          </div>

          <div class="cert-footer-row">
            <div class="cert-sig">
              <span class="cert-sig-line"></span>
              <span class="cert-sig-label">作者 · 雪云飞星</span>
              <span class="cert-no" id="certNo">No. ——</span>
            </div>
            <div class="cert-stamp">
              <span class="cert-stamp-check">✓</span>
              <span>认 证</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 操作按钮 -->
      <div class="cert-actions">
        <button class="btn-secondary" id="renameBtn">重新填写姓名</button>
      </div>
    </div>
    </Fragment>
    ) : (
    <!-- 证书功能未开放 -->
    <div class="state state-pending">
      <div class="pending-icon">🔜</div>
      <h1>证书功能即将开放</h1>
      <p class="desc">
        课程内容持续更新完善中，待所有章节发布后即可开放证书领取。<br />
        请保持关注，感谢你的耐心等待！
      </p>
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/chapters`} class="btn-primary">继续学习 →</a>
    </div>
    )}

  </div>
</BaseLayout>

<script define:vars={{ totalArticles }} is:inline>
  // ── 内联进度 localStorage 逻辑 ─────────────────────────
  const STORAGE_KEY = 'rust-tutorial-progress';

  function loadStore() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    } catch {
      return {};
    }
  }

  function getProgress(total) {
    if (total === 0) return 0;
    const store = loadStore();
    const articles = store.articles || {};
    let weight = 0;
    for (const ap of Object.values(articles)) {
      const vals = Object.values(ap.sections || {});
      if (vals.length > 0) {
        weight += vals.filter(Boolean).length / vals.length;
      } else if (ap.status === 'completed') {
        weight += 1;
      }
    }
    return Math.round(weight / total * 100);
  }

  function getCert() {
    return loadStore().certificate || null;
  }

  function saveName(name) {
    const store = loadStore();
    const existing = store.certificate;
    const earnedAt = (existing && existing.earnedAt) ? existing.earnedAt : new Date().toISOString();
    const certNo = (existing && existing.certNo) ? existing.certNo : generateCertNo(earnedAt);
    store.certificate = { name, earnedAt, certNo };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(store));
  }

  // 从 earnedAt 确定性生成证书编号，改名不影响编号
  function generateCertNo(earnedAt) {
    const d = new Date(earnedAt);
    const ymd = `${d.getFullYear()}${String(d.getMonth() + 1).padStart(2, '0')}${String(d.getDate()).padStart(2, '0')}`;
    const suffix = String(d.getTime() % 100000).padStart(5, '0');
    return `RUST-${ymd}-${suffix}`;
  }

  // ── 格式化日期 ─────────────────────────────────────────
  function formatDate(isoStr) {
    const d = new Date(isoStr);
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}年${m}月${day}日`;
  }

  // ── 状态机：决定显示哪个区块 ──────────────────────────
  function render() {
    const progress = getProgress(totalArticles);
    const cert = getCert();

    // 隐藏全部
    document.querySelectorAll('.state').forEach(el => {
      el.style.display = 'none';
    });

    if (progress < 100) {
      // 状态一
      const el = document.querySelector('.state-locked');
      el.style.display = 'block';
      el.querySelectorAll('.pct-text').forEach(span => {
        span.textContent = progress + '%';
      });
      el.querySelector('.progress-fill').style.width = progress + '%';
    } else {
      if (!cert || !cert.name) {
        // 状态二
        document.querySelector('.state-name-form').style.display = 'block';
      } else {
        // 状态三
        const el = document.querySelector('.state-certificate');
        el.style.display = 'block';
        document.getElementById('certName').textContent = cert.name;
        document.getElementById('certPct').textContent = progress + '%';
        document.getElementById('certDate').textContent =
          cert.earnedAt ? formatDate(cert.earnedAt) : '——';
        document.getElementById('certNo').textContent =
          'No. ' + (cert.certNo || generateCertNo(cert.earnedAt || new Date().toISOString()));
      }
    }
  }

  // ── 表单提交 ───────────────────────────────────────────
  document.getElementById('nameForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const input = document.getElementById('nameInput');
    const name = input.value.trim();
    const errEl = document.getElementById('formError');
    if (!name) {
      errEl.style.display = 'block';
      input.focus();
      return;
    }
    errEl.style.display = 'none';
    saveName(name);
    render();
  });

  // 隐藏错误提示当用户开始输入
  document.getElementById('nameInput').addEventListener('input', function() {
    document.getElementById('formError').style.display = 'none';
  });

  // ── 重新填写姓名 ───────────────────────────────────────
  document.getElementById('renameBtn').addEventListener('click', function() {
    saveName('');
    document.getElementById('nameInput').value = '';
    render();
  });

  // ── 初始渲染 ───────────────────────────────────────────
  render();
</script>

<style>
  /* ── 页面容器 ───────────────────────────────────────── */
  .cert-page {
    max-width: 700px;
    margin: 0 auto;
    padding: 6rem 1.5rem 4rem;
    min-height: calc(100vh - var(--navbar-height) - 80px);
  }

  /* ── 三个状态块的公共样式 ──────────────────────────── */
  .state {
    text-align: center;
  }

  /* ── 状态一：锁定 ─────────────────────────────────── */
  .lock-icon,
  .congrats-icon {
    font-size: 3rem;
    margin-bottom: 1.25rem;
    line-height: 1;
  }

  .state-locked h1,
  .state-name-form h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .desc {
    color: var(--color-text-muted);
    margin-bottom: 1.75rem;
    font-size: 1rem;
    line-height: 1.6;
  }

  .desc strong {
    color: var(--color-text);
  }

  /* 进度条 */
  .progress-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .progress-track {
    flex: 1;
    height: 3px;
    background: var(--color-border);
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: 999px;
    transition: width 0.4s ease;
  }

  .progress-label {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    min-width: 2.5rem;
    text-align: right;
  }

  /* ── 状态二：姓名表单 ─────────────────────────────── */
  .name-form {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .name-input {
    padding: 0.625rem 1rem;
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.9375rem;
    font-family: var(--font-body);
    min-width: 200px;
    flex: 1 1 200px;
    max-width: 320px;
    transition: border-color 0.15s;
  }

  .name-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .name-input::placeholder {
    color: var(--color-text-muted);
  }

  .form-error {
    color: var(--color-error);
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }

  /* ── 状态三：证书卡片 ─────────────────────────────── */
  .state-certificate {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .cert-card {
    width: 100%;
    background: var(--color-surface);
    border: 1.5px solid rgba(206, 65, 43, 0.5);
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 0 60px rgba(206, 65, 43, 0.08),
      0 8px 32px rgba(0, 0, 0, 0.5);
  }

  .cert-top-bar {
    height: 4px;
    background: linear-gradient(90deg, var(--color-accent), rgba(206, 65, 43, 0.4));
  }

  .cert-inner {
    padding: 3rem 3rem 2.5rem;
    text-align: center;
  }

  /* 标题区 */
  .cert-header {
    margin-bottom: 1.75rem;
  }

  .cert-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .cert-subtitle {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.25em;
  }

  /* 装饰分隔 */
  .cert-divider-wrap {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 2rem;
  }

  .cert-divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
  }

  .cert-divider-diamond {
    font-size: 0.5rem;
    color: var(--color-accent);
    opacity: 0.7;
    line-height: 1;
  }

  /* 正文 */
  .cert-body {
    margin-bottom: 2.5rem;
  }

  .cert-label {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    letter-spacing: 0.2em;
    margin-bottom: 0.875rem;
  }

  .cert-name {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1.25rem;
    line-height: 1.2;
    word-break: break-word;
  }

  .cert-completion {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .cert-pct {
    color: var(--color-accent);
    font-weight: 600;
  }

  .cert-date {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    opacity: 0.7;
    letter-spacing: 0.04em;
  }

  /* 底部：签名 + 印章 */
  .cert-footer-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .cert-sig {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.375rem;
  }

  .cert-sig-line {
    display: block;
    width: 100px;
    height: 1px;
    background: var(--color-border);
  }

  .cert-sig-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.06em;
  }

  .cert-no {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    opacity: 0.5;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    margin-top: 0.125rem;
  }

  .cert-stamp {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    border: 2px solid var(--color-accent);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    color: var(--color-accent);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    box-shadow: 0 0 16px rgba(206, 65, 43, 0.2);
    flex-shrink: 0;
  }

  .cert-stamp-check {
    font-size: 1.25rem;
    line-height: 1;
  }

  /* 操作按钮行 */
  .cert-actions {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
  }

  /* 证书未开放状态 */
  .state-pending {
    text-align: center;
    padding-top: 2rem;
  }

  .pending-icon {
    font-size: 3rem;
    margin-bottom: 1.25rem;
    line-height: 1;
  }

  .state-pending h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
</style>
