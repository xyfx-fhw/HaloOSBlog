---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-brand"><span class="accent">RUST</span> 互动教程</span>
    </div>
    <div class="footer-center">
      <span class="footer-meta">
        <img src={`${base}/images/logo.svg`} alt="雪云飞星" class="footer-avatar" width="16" height="16" loading="lazy" />
        作者：雪云飞星
      </span>
    </div>
    <div class="footer-right">
      <span class="footer-copy">© {year} fuhaowen. 保留所有权利.</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem;
    margin-top: 1rem;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-left {
    display: flex;
    align-items: center;
  }

  .footer-center {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .footer-brand {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .accent {
    color: var(--color-accent);
  }

  .footer-meta,
  .footer-copy {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .footer-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .footer-avatar {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    flex-shrink: 0;
  }
</style>
