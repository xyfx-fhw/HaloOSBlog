---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-brand"><span class="accent">RUST</span> 互动教程</span>
      <span class="footer-meta">作者：雪云飞星</span>
    </div>
    <div class="footer-right">
      <span class="footer-copy">© {year} fuhaowen. 保留所有权利.</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-left,
  .footer-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .accent {
    color: var(--color-accent);
  }

  .footer-meta,
  .footer-copy {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
</style>
