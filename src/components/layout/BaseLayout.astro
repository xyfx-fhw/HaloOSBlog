---
import '../../styles/global.css';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import { buildNavTree, getFlatArticleList } from '../../lib/content';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'RUST 互动教程 — 零基础系统学习 Rust 语言',
} = Astro.props;

const navTree = await buildNavTree();
const firstChapterHref = navTree[0]?.href ?? '/chapters';
const flatList = await getFlatArticleList(navTree);
const totalArticles = flatList.length;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — RUST 互动教程</title>
  </head>
  <body>
    <div class="page-bg" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>
    <Navbar firstChapterHref={firstChapterHref} totalArticles={totalArticles} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    padding-top: var(--navbar-height);
  }

  .page-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 640px;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
  }

  .orb-1 {
    width: 750px;
    height: 550px;
    background: radial-gradient(ellipse at 50% 55%,
      rgba(220, 60, 30, 0.60), transparent 62%);
    top: -280px;
    left: 50%;
    animation: orb-pulse-1 10s ease-in-out infinite;
  }

  .orb-2 {
    width: 520px;
    height: 420px;
    background: radial-gradient(ellipse at 55% 50%,
      rgba(20, 160, 200, 0.55), transparent 60%);
    top: -200px;
    left: -80px;
    animation: orb-pulse-2 13s ease-in-out infinite;
  }

  .orb-3 {
    width: 460px;
    height: 380px;
    background: radial-gradient(ellipse at 45% 50%,
      rgba(150, 40, 220, 0.50), transparent 60%);
    top: -180px;
    right: -60px;
    animation: orb-pulse-3 16s ease-in-out infinite;
  }

  /* orb-1：橙→黄绿，10s 一周期 */
  @keyframes orb-pulse-1 {
    0%        { opacity: 1;    filter: blur(72px) hue-rotate(0deg);   transform: translateX(-50%) scale(1); }
    50%       { opacity: 0.45; filter: blur(72px) hue-rotate(90deg);  transform: translateX(-48%) scale(1.08); }
    100%      { opacity: 1;    filter: blur(72px) hue-rotate(0deg);   transform: translateX(-50%) scale(1); }
  }

  /* orb-2：青蓝→暖橙，13s，反向转 */
  @keyframes orb-pulse-2 {
    0%        { opacity: 0.25; filter: blur(72px) hue-rotate(0deg);    transform: translate(0, 0) scale(1); }
    45%       { opacity: 1;    filter: blur(72px) hue-rotate(-110deg); transform: translate(35px, 15px) scale(1.12); }
    100%      { opacity: 0.25; filter: blur(72px) hue-rotate(0deg);    transform: translate(0, 0) scale(1); }
  }

  /* orb-3：紫→青蓝，16s */
  @keyframes orb-pulse-3 {
    0%, 100%  { opacity: 0.2;  filter: blur(72px) hue-rotate(0deg);   transform: translate(0, 0) scale(1); }
    55%       { opacity: 0.9;  filter: blur(72px) hue-rotate(130deg); transform: translate(-30px, 10px) scale(1.1); }
  }
</style>
