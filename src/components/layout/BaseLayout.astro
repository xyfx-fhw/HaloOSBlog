---
import '../../styles/global.css';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import { buildNavTree, getFlatArticleList } from '../../lib/content';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'HaloOS 系列讲解 — 整车操作系统架构与核心技术',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navTree = await buildNavTree();
const firstChapterHref = navTree[0]?.href ?? `${base}/chapters`;
const flatList = await getFlatArticleList(navTree);
const totalArticles = flatList.length;
const articleSlugs = flatList.map(a => a.slug);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title} — HaloOS 系列讲解</title>
    <script async src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
  </head>
  <body>
    <div class="page-bg" aria-hidden="true">
      <canvas id="matrix-bg-canvas"></canvas>
    </div>
    <Navbar firstChapterHref={firstChapterHref} totalArticles={totalArticles} articleSlugs={articleSlugs} />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function () {
        const canvas = document.getElementById('matrix-bg-canvas');
        if (!canvas || !(canvas instanceof HTMLCanvasElement)) return;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        const FONT_SIZE  = 16;  // 字号
        const COL_GAP    = 20;  // 列间距（横向密度）
        const TAIL_MIN   = 10;   // 流的最短尾巴（字符数）
        const TAIL_MAX   = 30;  // 流的最长尾巴
        const SPEED_MIN  = 0.4; // 最慢下落速度（单位：行/帧）
        const SPEED_MAX  = 0.6; // 最快下落速度

        // 统一的流创建函数：head 随机分布在完整周期内（屏幕上 + 屏幕外）
        // 这样任意时刻各列处于周期的不同阶段，不会同步空屏
        function makeStream() {
          const tailLen = TAIL_MIN + Math.floor(Math.random() * (TAIL_MAX - TAIL_MIN));
          const cycleLen = totalRows + tailLen + 4;
          return {
            head:    Math.floor(Math.random() * cycleLen) - tailLen,
            tailLen: tailLen,
            speed:   SPEED_MIN + Math.random() * (SPEED_MAX - SPEED_MIN),
            chars:   Array.from({ length: tailLen }, () => Math.random() < 0.5 ? '0' : '1'),
          };
        }

        let streams = [];
        let totalRows = 0;
        let totalCols = 0;
        ctx.font = `bold ${FONT_SIZE}px 'JetBrains Mono', monospace`;

        function init() {
          const parent = canvas.parentElement;
          if (!parent) return;
          canvas.width  = parent.offsetWidth;
          canvas.height = parent.offsetHeight;
          totalRows = Math.ceil(canvas.height / FONT_SIZE);
          totalCols = Math.ceil(canvas.width  / COL_GAP);
          streams = Array.from({ length: totalCols }, () => makeStream());
        }

        init();
        window.addEventListener('resize', init);

        function draw() {
          // 每帧完整清空，杜绝叠加
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.font = `bold ${FONT_SIZE}px 'JetBrains Mono', monospace`;

          for (let col = 0; col < streams.length; col++) {
            const s = streams[col];
            const x = col * COL_GAP;

            // 绘制整条流：从头部往上数 tailLen 个字符
            for (let t = 0; t < s.tailLen; t++) {
              const row = Math.floor(s.head) - t;
              if (row < 0 || row >= totalRows) continue;

              const y = row * FONT_SIZE + FONT_SIZE;

              // 越靠近尾巴越透明
              const tailAlpha = 1 - t / s.tailLen;
              // 越靠下越透明（渐变淡出到背景色）
              const yAlpha = Math.max(0, 1 - y / canvas.height);
              const alpha = tailAlpha * yAlpha;

              if (t === 0) {
                // 头部：比尾部亮一些，但不要太突兀
                ctx.fillStyle = `rgba(140, 220, 140, ${yAlpha})`;
              } else {
                ctx.fillStyle = `rgba(0, 114, 109, ${alpha * 0.9})`;
              }

              // 随机翻转头部字符，其余保持不动
              const char = (t === 0 && Math.random() < 0.15)
                ? (Math.random() < 0.5 ? '0' : '1')
                : s.chars[t % s.tailLen];

              ctx.fillText(char, x, y);
            }

            // 推进流
            s.head += s.speed;

            // 流的头部超出底部一段距离后重置
            if (Math.floor(s.head) > totalRows + s.tailLen + 2) {
              streams[col] = makeStream(totalRows);
            }
          }
        }

        setInterval(draw, 80);
      })();
    </script>
    </script>
  </body>
</html>

<style>
  main {
    padding-top: var(--navbar-height);
    position: relative;
    z-index: 1;
  }

  .page-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 320px;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  #matrix-bg-canvas {
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0.4;
  }
</style>
