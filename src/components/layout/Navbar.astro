---
interface Props {
  firstChapterHref?: string;
  totalArticles?: number;
  articleSlugs?: string[];
}

const { firstChapterHref = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/chapters`, totalArticles = 0, articleSlugs = [] } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="navbar">
  <div class="navbar-inner">
    <a href={import.meta.env.BASE_URL} class="logo">
      <span class="logo-rust">HaloOS</span> 系列讲解
    </a>
    <nav class="nav-links">
      <a
        href={import.meta.env.BASE_URL}
        class:list={['nav-link', { active: currentPath === base + '/' || currentPath === base }]}
        aria-current={(currentPath === base + '/' || currentPath === base) ? 'page' : undefined}
      >
        首页
      </a>
      <a
        href={firstChapterHref}
        id="tutorial-nav-link"
        class:list={['nav-link', { active: currentPath.startsWith(base + '/chapters') }]}
      >
        教程
      </a>
    </nav>
    <a href={`${base}/certificate`} class="nav-progress" id="nav-progress"
      data-total={totalArticles}
      data-slugs={JSON.stringify(articleSlugs)}>
      <span id="nav-progress-text">总进度：0%</span>
      <span class="nav-progress-tip">100% 后可获得证书</span>
    </a>
  </div>
</header>

<script define:vars={{ firstChapterHref, articleSlugs }} is:inline>
  const base = firstChapterHref.replace(/\/chapters\/?$/, '');
  const STORAGE_KEY = 'rust-tutorial-last-visited:' + base;
  const last = localStorage.getItem(STORAGE_KEY);
  if (last) {
    if (articleSlugs.some(s => last === base + '/chapters/' + s)) {
      const link = document.getElementById('tutorial-nav-link');
      if (link) link.href = last;
    } else {
      localStorage.removeItem(STORAGE_KEY);
    }
  }
</script>

<script>
  import { getOverallProgress } from '../../lib/progress';

  (function refreshNavProgress() {
    const el = document.getElementById('nav-progress') as HTMLElement | null;
    if (!el) return;
    const total = parseInt(el.dataset.total ?? '0', 10);
    if (total === 0) return;
    const validSlugs = new Set<string>(JSON.parse(el.dataset.slugs ?? '[]'));

    function update() {
      if (!el) return;
      const pct = getOverallProgress(total, validSlugs);
      const textEl = document.getElementById('nav-progress-text');
      const tipEl = el.querySelector('.nav-progress-tip') as HTMLElement | null;
      if (pct >= 100) {
        if (textEl) textEl.textContent = '🎓 证书已解锁';
        el.classList.add('nav-progress--unlocked');
        if (tipEl) tipEl.textContent = '点击领取你的学习证书';
      } else {
        if (textEl) textEl.textContent = `总进度：${pct}%`;
        el.classList.remove('nav-progress--unlocked');
        if (tipEl) tipEl.textContent = '100% 后可获得证书';
      }
    }

    update();
    window.addEventListener('progress-updated', update);
  })();
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    height: var(--navbar-height);
  }

  .navbar-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .logo {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .logo:hover {
    text-decoration: none;
    color: var(--color-text);
  }

  .logo-rust {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    gap: 0.25rem;
    flex: 1;
  }

  .nav-link {
    position: relative;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    font-size: 0.875rem;
    transition: color 0.15s, background 0.15s;
  }

  .nav-link:hover {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.05);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-text);
    pointer-events: none;
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0.75rem;
    right: 0.75rem;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }

  .nav-progress {
    position: relative;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    text-decoration: none;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    transition: color 0.15s, border-color 0.15s, background 0.15s, transform 0.1s, box-shadow 0.1s;
  }

  .nav-progress:hover {
    color: var(--color-text);
    border-color: rgba(206, 65, 43, 0.4);
    background: rgba(206, 65, 43, 0.06);
    text-decoration: none;
  }

  .nav-progress:active {
    transform: scale(0.96);
    background: rgba(206, 65, 43, 0.1);
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  /* 100% 解锁状态 */
  .nav-progress--unlocked {
    color: var(--color-accent);
    font-weight: 600;
    border-color: rgba(206, 65, 43, 0.5);
    background: rgba(206, 65, 43, 0.08);
  }

  .nav-progress--unlocked:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: rgba(206, 65, 43, 0.14);
  }

  .nav-progress-tip {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.3rem 0.625rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.15s, transform 0.15s;
  }

  .nav-progress:hover .nav-progress-tip {
    opacity: 1;
    transform: translateY(0);
  }
</style>
