---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter(h => h.depth >= 1 && h.depth <= 3);
---

{tocHeadings.length > 0 && (
  <aside class="page-toc">
    <p class="toc-title">目录</p>
    <nav aria-label="页内目录">
      <ul class="toc-list">
        {tocHeadings.map(h => (
          <li class:list={['toc-item', `toc-h${h.depth}`]}>
            <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}

<script>
  const toc = document.querySelector<HTMLElement>('.page-toc');
  const links = toc
    ? Array.from(toc.querySelectorAll<HTMLAnchorElement>('.toc-link'))
    : [];

  if (links.length > 0) {
    const headingEls = links.map(l => {
      const id = l.getAttribute('href')?.slice(1);
      return id ? document.getElementById(id) : null;
    });

    let activeIdx = -1;
    const activate = (idx: number) => {
      if (idx === activeIdx) return;
      if (activeIdx >= 0) links[activeIdx]?.classList.remove('active');
      activeIdx = idx;
      links[activeIdx]?.classList.add('active');
    };

    // IntersectionObserver 追踪当前可见标题
    // hidden 的 tab-panel 内的元素不会 intersect，自动只高亮可见 tab 的标题
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const idx = headingEls.indexOf(entry.target as HTMLElement);
            if (idx !== -1) activate(idx);
          }
        });
      },
      { rootMargin: '-10% 0px -80% 0px', threshold: 0 }
    );

    headingEls.forEach(el => el && observer.observe(el));

    // tab 切换时，主动激活新 tab 第一个标题（Observer 的窄观察带不可靠）
    window.addEventListener('sp-tab-changed', (e: Event) => {
      const tabIdx = (e as CustomEvent<{ tabIdx: number }>).detail.tabIdx;
      const panel = document.querySelector<HTMLElement>(`.tab-panel[data-tab-idx="${tabIdx}"]`);
      if (!panel) return;
      for (let i = 0; i < headingEls.length; i++) {
        if (headingEls[i] && panel.contains(headingEls[i]!)) {
          activate(i);
          break;
        }
      }
    });

    // 拦截 TOC 链接点击，处理跨标签跳转
    // 不阻止默认行为，让浏览器在 tab 切换后自动滚动到锚点
    links.forEach(link => {
      link.addEventListener('click', () => {
        const href = link.getAttribute('href');
        if (!href?.startsWith('#')) return;
        const targetEl = document.getElementById(href.slice(1));
        if (!targetEl) return;

        const panel = targetEl.closest<HTMLElement>('.tab-panel');
        if (!panel) return;

        const tabIdx = parseInt(panel.dataset.tabIdx ?? '0', 10);
        window.dispatchEvent(
          new CustomEvent('sp-switch-tab', { detail: { tabIdx } })
        );
      });
    });
  }
</script>

<style>
  .page-toc {
    width: 200px;
    flex-shrink: 0;
    position: sticky;
    top: calc(var(--navbar-height) + 1.5rem);
    max-height: calc(100vh - var(--navbar-height) - 3rem);
    overflow-y: auto;
    padding: 0 1rem 1rem 0.5rem;
    align-self: flex-start;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .toc-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--color-border);
  }

  /* H1：顶层，加粗 */
  .toc-h1 .toc-link {
    font-weight: 600;
    font-size: 0.8125rem;
  }

  /* H2：一级缩进 */
  .toc-h2 {
    padding-left: 0.875rem;
  }

  /* H3：二级缩进 */
  .toc-h3 {
    padding-left: 1.75rem;
  }

  .toc-link {
    display: block;
    padding: 0.25rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    line-height: 1.5;
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 0.15s, border-color 0.15s;
  }

  .toc-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .toc-link.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }
</style>
